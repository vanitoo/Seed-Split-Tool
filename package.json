{
  "name": "seed-split-tool",
  "version": "0.5.1",
  "private": true,
  "description": "Privacy-first offline seed generation, secret sharing and recovery with SLIP-39, Banana Split and generic Shamir support.",
  "scripts": {
    "dev": "next dev --hostname localhost --port 3200",
    "build": "next build --webpack",
    "start": "next start --hostname localhost --port 3200",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:crypto": "node scripts/crypto-smoke.mjs",
    "test:slip39-vectors": "node scripts/slip39-official-vectors.mjs",
    "check": "npm run test:crypto && npm run test:slip39-vectors && npm run typecheck && npm run lint && npm run build"
  },
  "dependencies": {
    "base64-js": "^1.5.1",
    "bip39": "^3.1.0",
    "buffer": "^6.0.3",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "scryptsy": "^2.1.0",
    "secrets.js-grempe": "^2.0.0",
    "slip39": "^0.1.9",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/base64-js": "^1.5.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
